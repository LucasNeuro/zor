  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.90.16",
    "@xyflow/react": "^12.10.1",
    "lucide-react": "^0.468.0",
    "ioredis": "^5.7.0",
    "next": "^16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "vitest": "^3.2.4"
