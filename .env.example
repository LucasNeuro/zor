# Copie para .env.local e preencha. Nunca commite segredos.

PORT=3001
NEXT_PUBLIC_APP_URL=https://waje.com.br

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# npm run dev já relaxa TLS no Node (só local). Se quiseres verificação estrita: npm run dev:strict-tls
# Alternativa empresarial: NODE_EXTRA_CA_CERTS=completo\para\corp-root.pem (nunca commites o ficheiro).

# Mesmo valor em dev (browser envia via NEXT_PUBLIC_INTERNAL_API_KEY em pedidos internos). Alternativa: sessão CRM (cookie) + Supabase no middleware — ver README «Proxy».
INTERNAL_API_KEY=
NEXT_PUBLIC_INTERNAL_API_KEY=

DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_TENANT_ID=00000000-0000-4000-8000-000000000001

# Modelo "utilizador = Auth + public.users" (papéis em app_role; status em record_status)
# LOGIN_ENFORCE_APP_USERS=true
# Opcional: só estes app_role abrem o backoffice (ex. bloquear só-leitura)
# LOGIN_ALLOWED_APP_ROLES=owner,admin

# Alternativa ao nome acima (mesmo efeito):
# LOGIN_REQUIRE_PUBLIC_USERS_ROW=true
# Exige linha em public.users com status Ativo mesmo sem LOGIN_REQUIRE_PUBLIC_USERS_ROW.
# LOGIN_ALLOWED_APP_ROLES=owner,admin

# Console operacional Waje (/crm/waje) — marque owner = true em public.users OU e-mails bootstrap:
# WAJE_OPS_ALLOWED_EMAILS=ops@waje.com.br,admin@waje.com.br
# Cron trial expirado: GET /api/cron/ops-tenant-trial (Bearer CRON_SECRET) — agendar 1x/dia.

# --- Cora (Integração Direta) — boletos mensalidade Waje ---
# Emissor = conta Cora ONNZE (62.449.971/0001-70). Pagador = CNPJ do cliente (ex. SHEFA).
# Baixe o zip em Cora Web → ONNZE → Integração Direta → produção (client_id + cert + key do MESMO zip).
# CORA_CLIENT_ID=int-1ZVwf7iYC106q3iRWEmyJP
# CORA_ENV=production
# Cole o conteúdo PEM (use \n para quebras de linha numa única linha no Render):
# CORA_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# CORA_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# CNPJ da conta Cora dona das credenciais — NÃO é o CNPJ do tenant cliente.
# CORA_EMISSOR_CNPJ=62.449.971/0001-70
# CORA_EMISSOR_NOME=ONNZE TECNOLOGIA LTDA

CRON_SECRET=
# WhatsApp: após enfileirar mensagem, o webhook dispara GET /api/cron/process-whatsapp-jobs (precisa CRON_SECRET + NEXT_PUBLIC_APP_URL no web).
# WHATSAPP_JOB_PROCESSOR=worker_only desliga o disparo automático (use só Background Worker).
# npm run validar:whatsapp — audita agentes/cargo no Supabase; validar:whatsapp:fix aplica correções.
# WHATSAPP_JOB_TRIGGER_TIMEOUT_MS=120000

# Opcional no hospedeiro do cron (ex. Render Cron Job): URL completa para GET /api/cron/dispatch-ciclos.
# Se vazio, usa NEXT_PUBLIC_APP_URL + /api/cron/dispatch-ciclos (alinhado a app/api/cron/dispatch-ciclos).
# DISPATCH_CICLOS_URL=

PORTAL_HMAC_SECRET=

# --- Provedores IA (operacional: WhatsApp/engine/briefing) — Mistral como caminho predefinido ---
# Motor de conversação: usa MISTRAL_API_KEY quando o agente não fixa um modelo Claude explícito.
MISTRAL_API_KEY=
# Modelo global Mistral (router, engine, playbooks, wizard). Ex.: mistral-small-latest, mistral-large-latest
MISTRAL_MODEL=mistral-small-latest
# Embeddings RAG (tabela hub_agente_rag_chunks). Padrão: mistral-embed (1024 dimensões).
# MISTRAL_EMBED_MODEL=mistral-embed

# Base de conhecimento (CRM → Conhecimento): leitura de documentos via Mistral Document AI (POST /v1/ocr).
# Activo por defeito quando MISTRAL_API_KEY está definida. Desligar: HUB_CONHECIMENTO_MISTRAL_DOCUMENT_AI=false
# MISTRAL_DOCUMENT_AI_MODEL=mistral-ocr-latest
# MISTRAL_DOCUMENT_AI_TIMEOUT_MS=120000

# Opcional: fluxos legados ou agentes com modelo `claude-*` explícito no CRM.
ANTHROPIC_API_KEY=

# Opcional — sugestão de cargos (`/api/hub/cargos/sugerir`) no CRM; fallback a MISTRAL_MODEL.
# HUB_CARGO_SUGESTAO_MISTRAL_MODEL=mistral-small-latest

# Google AI (Gemini) — opcional: camada «smart» em ferramentas Hub custom (`smart_provider: gemini`)
# Use uma única variável; não commite valores reais.
GOOGLE_AI_API_KEY=
# Alternativa aceite pelo código (mesmo efeito que GOOGLE_AI_API_KEY):
# GEMINI_API_KEY=


# Fallback opcional se Mistral falhar no wizard "Gerar com IA"
# AGENTE_WIZARD_CONHECIMENTO_MODEL=claude-haiku-4-5-20251001

# --- Playbooks Agno (bucket Supabase `hub-agent-playbooks`) ---
# Upload pós-criação/atualização de agente; MIME permitido inclui text/markdown (ver migrações).
# Requer SUPABASE_SERVICE_ROLE_KEY na API Next.js.
# Teste local do pipeline pós-criação (com `npm run dev`): `npm run smoke:playbook`

# --- E-mail: OAuth (canal_email — Google + Microsoft; preferido) ---
# Canal de mensagens por e-mail (desactivado por defeito). Activar só quando Resend/OAuth estiver pronto.
# ENABLE_EMAIL_CHANNEL=false
# NEXT_PUBLIC_ENABLE_EMAIL_CHANNEL=false
# Ver também GOOGLE_OAUTH_* e MICROSOFT_OAUTH_* abaixo.

# --- E-mail: Resend (legado — opcional se usar só OAuth) ---
# API key do tenant (server-side apenas; nunca NEXT_PUBLIC_).
RESEND_API_KEY=
# Remetente padrão global quando o agente não define email_from (ex.: Atendimento <noreply@seudominio.com>).
RESEND_FROM_EMAIL=
# Segredo do webhook POST /api/email/inbound (Bearer, cabeçalho ou query ?eh=).
EMAIL_INBOUND_WEBHOOK_SECRET=
# Cron Gmail OAuth inbox sync: GET/POST /api/cron/email-sync (Bearer CRON_SECRET, 1–5 min).
# Agente canal_email: email_provider=oauth_google + email_integracao_id → hub_integracoes (tipo gmail).
# Opcional: nome do cabeçalho com o segredo (default x-email-webhook-secret).
# EMAIL_INBOUND_WEBHOOK_SECRET_HEADER=x-email-webhook-secret
# Opcional: query param do segredo na URL (default eh).
# EMAIL_INBOUND_WEBHOOK_SECRET_QUERY_PARAM=eh
# Apenas local: aceita POST sem verificação (não usar em produção).
# EMAIL_WEBHOOK_SKIP_VERIFY=true

# --- E-mail: Gmail OAuth (canal_email por tenant — alternativa ao Resend) ---
# Google Cloud Console → OAuth 2.0 Client (Web).
# Registe TODOS os callbacks dos domínios white-label, ex.:
#   https://waje.com.br/api/hub/email/oauth/google/callback
#   https://synkronia.com.br/api/hub/email/oauth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI é fallback se o domínio não for marca conhecida (opcional).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Chave AES-256 para encriptar refresh/access tokens em hub_integracao_credenciais (32 bytes hex ou base64).
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HUB_CREDENTIALS_ENCRYPTION_KEY=

# Fuso para eventos Calendar — fallback se tenant ainda não configurou hub_tenant_agenda_config
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
# Fallback global (por tenant: CRM → Agente → Integrações → Google → Horário da agenda)
GOOGLE_CALENDAR_DURACAO_RESERVA_MIN=90
GOOGLE_CALENDAR_ABERTURA=11:30
GOOGLE_CALENDAR_FECHAMENTO=23:00
GOOGLE_CALENDAR_COM_MEET=false

# --- E-mail: Microsoft 365 / Outlook OAuth (em implementação) ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# Default: {NEXT_PUBLIC_APP_URL}/api/hub/email/oauth/microsoft/callback
MICROSOFT_OAUTH_REDIRECT_URI=

# --- WhatsApp: UAZAPI (único provedor — webhook + envio) ---
# Painel: URL do servidor (ex. https://SUBDOMINIO.uazapi.com). Sem sufixo /api — o código remove /api se existir.
# Se o seu host usar prefixo extra (raro), defina UAZAPI_PATH_PREFIX= ex. v1 -> pedidos a {BASE}/v1/instance/create
UAZAPI_BASE_URL=
# UAZAPI_PATH_PREFIX=
UAZAPI_INSTANCE_TOKEN=
# Sem UAZAPI: em `next dev` a Central grava mensagem no CRM/chat sem enviar WhatsApp.
# WHATSAPP_DRY_RUN=1
# Obrigatório para criar/eliminar instâncias no CRM (header admintoken).
# UAZAPI_ADMIN_TOKEN=
# Opcional: token de qualquer instância já existente no mesmo servidor — só para pré-carregar cidades antes do 1.º agente.
# UAZAPI_BOOTSTRAP_INSTANCE_TOKEN=
# Listar cidades (GET /proxy-managed/cities) exige token de instância, não admin — após «Criar instância» no agente usa o token novo.
# Cidade do proxy UAZAPI: configurar por agente no CRM (hub_agente_identidade), não variável global.

WEBHOOK_SECRET=
WEBHOOK_SECRET_HEADER=x-webhook-secret
# White-label: UAZAPI sempre neste domínio (não muda ao ligar WhatsApp em synkronia.com.br).
# WHATSAPP_WEBHOOK_PUBLIC_ORIGIN=https://waje.com.br
# Apenas local: em produção use https://waje.com.br (nunca localhost — UAZAPI não alcança).
# WEBHOOK_SKIP_SIGNATURE_VERIFY=true
WHATSAPP_VERIFY_TOKEN=
# Slug gravado em hub_leads_crm.humano_responsavel quando alguém responde pelo celular da linha (fromMe).
# WHATSAPP_DEVICE_HUMAN_SLUG=wendel

# --- Worker WhatsApp (consumo de hub_msg_jobs) ---
WORKER_POLL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_CONCURRENCY=4
# jitter opcional para reduzir thundering herd entre réplicas
# WORKER_JITTER_MS=400

# Timeouts/retries do cliente Mistral usados no processamento em background
MISTRAL_CHAT_TIMEOUT_MS=30000
MISTRAL_CHAT_RETRIES=1

# Mistral adjustable reasoning (mistral-small-latest, mistral-medium-3-5)
# none = default rápido; high = thinking trace (mais tokens/latência)
MISTRAL_REASONING_EFFORT=none
# Com 1, reasoning só em turnos playbook_ia (WhatsApp híbrido)
# MISTRAL_REASONING_EFFORT_PLAYBOOK_IA_ONLY=1
# Por agente: ligue «Raciocínio avançado» em CRM → Agente → Ferramentas IA (hub_raciocinio_avancado)

# Após reindex de doc tenant: regenerar análise do negócio automaticamente
# HUB_CONHECIMENTO_AUTO_REGEN_ANALISE=1

# Playbook WhatsApp — ver docs/rollout-agentes-wa.md
# PLAYBOOK_HYBRID_IA=1
# PLAYBOOK_MENU_UAZAPI_ENHANCE=1

# Mensagens de contexto da conversa enviadas ao modelo (2–24, default 10)
HUB_ENGINE_HISTORICO_MENSAGENS=10

# Janela de memória ativa por lead (mesmo telefone): após N horas sem mensagem, novo «Olá» = sessão nova (default 12).
# Reinicia: turnos/metadata de fluxo, interesse_principal, valor_estimado, memórias IA (mantém nome, telefone, estágio CRM).
HUB_SESSAO_CONVERSA_TTL_HORAS=12

# Gera resumo automático quando a conversa atinge N mensagens (default 30)
HUB_CONVERSA_RESUMO_APARTIR=30

# Modelo Mistral barato para memória e resumos (default mistral-small-latest)
MISTRAL_MEMORY_MODEL=mistral-small-latest

WINDSOR_API_KEY=

# Limite POST /api/parceiros/portal/verify (por IP, janela em memória)
PORTAL_VERIFY_RATE_MAX=40
PORTAL_VERIFY_RATE_WINDOW_MS=60000

# Dashboard CRM: Supabase Realtime nas métricas (false = menos carga em dev)
NEXT_PUBLIC_ENABLE_REALTIME_METRICAS=true

# --- CRM PDF (funil operacional + encaminhamento) — staging primeiro, depois produção ---
# Pipeline V2: dual-write estagio + estagio_funil; kanban usa etapas PDF.
CRM_PIPELINE_V2=true
# Encaminhamento rastreável (POST /api/crm/encaminhamentos).
CRM_ENCAMINHAMENTO_V2=true
# Exige próxima ação em etapas ativas (ligar após validação).
CRM_PROXIMA_ACAO_OBRIGATORIA=false
# Grava mudanças de etapa em hub_logs.
CRM_LOGS_AUDITORIA=true
