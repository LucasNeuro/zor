    "test": "vitest run",
    "smoke:playbook": "node scripts/smoke-agent-playbook.cjs",
    "checklist:hub": "node scripts/verify-hub-checklist.cjs",
    "smoke:webhook": "node scripts/smoke-whatsapp-webhook.cjs",
    "diagnose:webhook": "node scripts/diagnose-uazapi-webhook.cjs",
