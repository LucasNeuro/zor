  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "node scripts/dev-insecure-tls.cjs",
    "dev:clean": "node scripts/clean-next-dev-cache.cjs && node scripts/dev-insecure-tls.cjs",
    "clean:next-dev": "node scripts/clean-next-dev-cache.cjs",
    "dev:strict-tls": "next dev -p 3001",
